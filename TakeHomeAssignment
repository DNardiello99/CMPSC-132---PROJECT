def findSmallestIndex(nums, target):
    # Track the minimum value among elements to the right
    min_after = float('inf')
    smallest = -1
    # Traverse from right to left (second last element to first)
    for i in range(len(nums) - 2, -1, -1):
        # Update the minimum value seen so far on the right
        min_after = min(min_after, nums[i + 1])
        # Check if all elements after index i are strictly greater than target
        if min_after > target:
            smallest = i
    return smallest

