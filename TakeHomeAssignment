class ListNode:
    def __init__ (self, val=0, next=None):
        self.val = val
        self.next = next

def find_cycle_length(head):
    if head is None:
        return -1
    slow = head
    fast = head
    cycle = False
    while fast is not None and fast.next is not None and not cycle:
        slow = slow.next
        fast = fast.next.next  
        if slow == fast:
            cycle = True
    if not cycle:
        return -1
    current = slow.next
    length = 1
    while current != slow:
        current = current.next
        length += 1
    return length
    pass

